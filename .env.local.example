# === Klartext Liebe – Umgebungsvariablen ===
# Diese Datei nach .env.local kopieren und mit echten Werten füllen.
# .env.local NIEMALS committen (steht in .gitignore).

# --- Supabase (Auth, Datenbank, Storage) ---
# TODO: Werte aus dem Supabase-Projekt eintragen (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nur serverseitig verwenden – niemals an den Client geben!
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Für das MVP reichen Payment Links (siehe lib/stripe-links.ts).
# Diese Keys erst nötig, wenn echte Checkout-/Webhook-Integration kommt.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Sonstiges ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://youtube.com/@klartextliebe
